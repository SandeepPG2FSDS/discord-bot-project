# From Discord Developer Portal -> your app -> General Information / Bot
DISCORD_PUBLIC_KEY=your_discord_public_key_hex
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_APPLICATION_ID=your_discord_application_id

# Slack Incoming Webhook URL, or a Discord channel webhook URL
MIRROR_WEBHOOK_URL=

# Postgres connection string from Neon or Supabase. Leave unset to use local SQLite.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require


# Throwaway admin login for the dashboard
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Random long string for signing dashboard login tokens
JWT_SECRET=

# Optional - only needed for the AI stretch goal (Groq free tier)
GROQ_API_KEY=
